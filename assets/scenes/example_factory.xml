<mujoco model="example_factory">
  <compiler angle="degree" coordinate="local" />

  <asset>
    <texture name="tex_floor" type="2d" builtin="checker" width="512" height="512"
             rgb1="0.3 0.3 0.3" rgb2="0.5 0.5 0.5" />
    <material name="mat_floor" texture="tex_floor" reflectance="0.1" />
  </asset>

  <worldbody>
    <!-- ── Lighting ──────────────────────────────────────────────────── -->
    <light name="key_light" directional="false"
           pos="2 2 3" dir="0 0 -1"
           diffuse="0.8 0.8 0.8" ambient="0.3 0.3 0.3" specular="0.2 0.2 0.2"
           castshadow="true" />

    <light name="fill_light" directional="false"
           pos="-1 1 2" dir="0 0 -1"
           diffuse="0.4 0.4 0.5" ambient="0.15 0.15 0.2" specular="0.1 0.1 0.1"
           castshadow="false" />

    <!-- Floor -->
    <geom name="floor" type="plane" pos="0 0 0" size="5 5 0.1" material="mat_floor" />

    <!-- Bin / container -->
    <body name="bin" pos="0 0 0.05">
      <geom name="bin_base" type="box" pos="0 0 -0.03" size="0.5 0.4 0.025"
            rgba="0.3 0.3 0.35 1" />
      <!-- Walls -->
      <geom name="bin_wall_left" type="box" pos="-0.48 0 0.05" size="0.02 0.4 0.075"
            rgba="0.4 0.4 0.45 1" />
      <geom name="bin_wall_right" type="box" pos="0.48 0 0.05" size="0.02 0.4 0.075"
            rgba="0.4 0.4 0.45 1" />
      <geom name="bin_wall_front" type="box" pos="0 0.38 0.05" size="0.5 0.02 0.075"
            rgba="0.35 0.35 0.4 1" />
      <geom name="bin_wall_back" type="box" pos="0 -0.38 0.05" size="0.5 0.02 0.075"
            rgba="0.35 0.35 0.4 1" />
    </body>

    <!-- Objects in bin -->
    <!-- Red cube -->
    <body name="cube_red" pos="-0.15 0.1 0.1">
      <geom name="cube_red_geom" type="box" size="0.04 0.04 0.04"
            rgba="0.9 0.2 0.2 1" />
    </body>

    <!-- Blue cube -->
    <body name="cube_blue" pos="0.1 -0.05 0.1">
      <geom name="cube_blue_geom" type="box" size="0.04 0.04 0.04"
            rgba="0.2 0.3 0.9 1" />
    </body>

    <!-- Green sphere -->
    <body name="sphere_green" pos="0.05 0.15 0.1">
      <geom name="sphere_green_geom" type="sphere" size="0.045"
            rgba="0.2 0.8 0.3 1" />
    </body>

    <!-- Yellow cylinder -->
    <body name="cylinder_yellow" pos="-0.05 -0.1 0.1">
      <geom name="cylinder_yellow_geom" type="cylinder" size="0.03 0.05"
            rgba="0.9 0.8 0.1 1" />
    </body>

    <!-- White small box -->
    <body name="box_white" pos="0.2 0.2 0.1">
      <geom name="box_white_geom" type="box" size="0.025 0.025 0.025"
            rgba="0.85 0.85 0.85 1" />
    </body>
    <!-- ── Cameras ────────────────────────────────────────────────────── -->
    <camera name="cam_front" mode="fixed"
            pos="0 1.5 1.2" quat="0.6 0.4 0.4 0.55"
            fovy="55" />

    <camera name="cam_top" mode="fixed"
            pos="0 0 3.0" quat="0.707 0.707 0 0"
            fovy="45" />

    <camera name="cam_side" mode="fixed"
            pos="1.5 0 1.0" quat="0.5 0.5 0.5 0.5"
            fovy="50" />

  </worldbody>

</mujoco>
