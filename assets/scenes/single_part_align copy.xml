<mujoco model="table_with_stl">
      <option gravity="0 0 0" />
  <compiler angle="degree" coordinate="local" />

  <asset>
    <!-- STL mesh — scale 0.001 assumes STL is in mm; adjust if needed -->
    <mesh name="mesh_A" file="../A-200MAOPI.stl" scale="0.001 0.001 0.001" />
    <!-- Table surface texture -->
    <texture name="tex_table" type="2d" builtin="checker" width="512" height="512"
             rgb1="0.55 0.45 0.35" rgb2="0.65 0.55 0.45" />
    <material name="mat_table" texture="tex_table" reflectance="0.05" />

    <!-- Floor texture -->
    <texture name="tex_floor" type="2d" builtin="checker" width="512" height="512"
             rgb1="0.25 0.25 0.25" rgb2="0.45 0.45 0.45" />
    <material name="mat_floor" texture="tex_floor" reflectance="0.1" />
  </asset>

  <worldbody>
    <!-- ── Lighting ──────────────────────────────────────────────────── -->
    <light name="key_light" directional="false"
           pos="2 2 3" dir="0 0 -1"
           diffuse="0.85 0.85 0.85" ambient="0.3 0.3 0.3" specular="0.2 0.2 0.2"
           castshadow="true" />

    <light name="fill_light" directional="false"
           pos="-1 1 2" dir="0 0 -1"
           diffuse="0.4 0.4 0.5" ambient="0.15 0.15 0.2" specular="0.1 0.1 0.1"
           castshadow="false" />

    <!-- ── Floor ─────────────────────────────────────────────────────── -->
    <geom name="floor" type="plane" pos="0 0 0" size="3 3 0.1" material="mat_floor" />

    <!-- ── Table ─────────────────────────────────────────────────────── -->
    <!-- Table top at z=0.4m, dimensions 1.0m x 0.8m x 0.025m -->
    
      
    <!-- ── STL Object ────────────────────────────────────────────────── -->
    <body name="obj_1" pos="0.0 0.0 0.43">
      <geom name="obj_1_geom" type="mesh" mesh="mesh_A"
            rgba="0.75 0.75 0.75 1" />
    </body>

    <!-- ── Movable camera body (no joint — controlled via body_pos / body_quat) ── -->
    <body name="cam_body" pos="0.3 0.3 0.6">
      <inertial pos="0 0 0" mass="0.01" diaginertia="1e-6 1e-6 1e-6"/>
      <camera name="align_cam" pos="0 0 0" quat="1 0 0 0" fovy="60" />
    </body>

    <!-- ── Fixed reference cameras ────────────────────────────────────── -->
    <camera name="cam_front" mode="fixed"
            pos="0 1.2 1.0" quat="0.55 0.45 0.45 0.55"
            fovy="50" />

    <camera name="cam_top" mode="fixed"
            pos="0 0 2.5" quat="0.707 0.707 0 0"
            fovy="45" />

    <camera name="cam_side" mode="fixed"
            pos="1.5 0 0.8" quat="0.5 0.5 0.5 0.5"
            fovy="50" />

  </worldbody>

</mujoco>
